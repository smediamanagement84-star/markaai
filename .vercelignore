# Vercel Ignore File
# Files and directories to exclude from deployment

# Development files
.env.local
.env*.local

# Testing
test-*.js
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
coverage/

# Documentation (optional - comment out if you want docs deployed)
TESTING_REPORT.md
ROUTES_TESTING_REPORT.md
FIXES_SUMMARY.md
DEV_GUIDE.md
VERCEL_DEPLOYMENT_GUIDE.md

# Development tools
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Claude AI
.claude/

# Build cache (will be regenerated)
.next/cache/

# Deployment scripts
deploy-to-vercel.ps1
deploy.bat
